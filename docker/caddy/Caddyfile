{
	skip_install_trust
}

app.{$PROXY_DOMAIN:local.gd} {
	tls internal

	handle /api/* {
		reverse_proxy php:80 {
			header_up Host php
		}
	}

	handle /.well-known/mercure* {
		reverse_proxy php:80 {
			header_up Host php
		}
	}

	handle /otlp/* {
		uri strip_prefix /otlp
		reverse_proxy otel-collector:4318
	}

	handle {
		reverse_proxy app:3000
	}
}

grafana.{$PROXY_DOMAIN:local.gd} {
	tls internal
	reverse_proxy grafana:3000
}

jaeger.{$PROXY_DOMAIN:local.gd} {
	tls internal
	reverse_proxy jaeger:16686
}

prometheus.{$PROXY_DOMAIN:local.gd} {
	tls internal
	reverse_proxy prometheus:9090
}
