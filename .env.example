# =============================================================================
# Image versions
# =============================================================================
CADDY_IMAGE=caddy:2-alpine
COLLECTOR_CONTRIB_IMAGE=ghcr.io/open-telemetry/opentelemetry-collector-releases/opentelemetry-collector-contrib:0.145.0
GRAFANA_IMAGE=grafana/grafana:12.3.1
TEMPO_IMAGE=grafana/tempo:2.9.1
LOKI_IMAGE=grafana/loki:3.6
PROMETHEUS_IMAGE=prom/prometheus:v3.10.0
JAEGER_IMAGE=jaegertracing/all-in-one:1.76.0

# =============================================================================
# Reverse Proxy
# =============================================================================
PROXY_DOMAIN=local.gd

# =============================================================================
# API / Symfony
# =============================================================================
IMAGES_PREFIX=
SYMFONY_VERSION=
STABILITY=stable

# =============================================================================
# Database
# =============================================================================
POSTGRES_VERSION=16
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=!ChangeMe!
POSTGRES_CHARSET=utf8
POSTGRES_PORT=5432

# =============================================================================
# Mercure / Caddy
# =============================================================================
CADDY_MERCURE_JWT_SECRET=!ChangeThisMercureHubJWTSecretKey!

# =============================================================================
# Development
# =============================================================================
APP_ENV=dev
XDEBUG_MODE=off

# =============================================================================
# Production only (uncomment and set for prod)
# =============================================================================
# APP_SECRET=
